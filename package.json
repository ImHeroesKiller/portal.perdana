{
  "name": "pt-perdana-recruitment",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "node scripts/optimize-images.mjs && node scripts/generate-pwa-icons.mjs && vite build && node scripts/inject-pwa-precache.mjs && node scripts/build-vercel-api.mjs",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "build:api": "node scripts/build-vercel-api.mjs",
    "build:server": "node scripts/build-server.mjs",
    "start": "node dist/server.cjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "init-firestore": "tsx scripts/init-firestore.ts",
    "test:firestore": "tsx scripts/test-firestore-connection.ts",
    "migrate:candidates": "tsx scripts/migrate-employees-to-candidates.ts"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@heroicons/react": "^2.1.1",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.17.0",
    "express": "^5.2.1",
    "firebase": "^12.14.0",
    "firebase-admin": "^14.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.8",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "esbuild": "^0.28.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5.2.2",
    "vite": "^5.1.0"
  }
}
