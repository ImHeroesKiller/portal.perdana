rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net Deny-all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'ztquality@gmail.com' || 
        (request.auth.token.email != null && request.auth.token.email.matches('^.*@perada[.]net$')) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Employees Collection Helper: Validates Employee Schema
    function isValidEmployee(data) {
      return data.keys().hasAll(['id', 'fullName', 'nik', 'email', 'status', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.fullName is string && data.fullName.size() <= 256 &&
             data.nik is string && data.nik.size() <= 20 &&
             data.email is string && data.email.size() <= 120 &&
             data.status is string && data.status.size() <= 30 &&
             data.createdAt is string;
    }

    // Employees Collection: Candidates and field workers
    match /employees/{employeeId} {
      allow create: if isValidId(employeeId) && isValidEmployee(request.resource.data);
      allow read: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow update: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email && isValidEmployee(request.resource.data));
      allow delete: if isAdmin();
    }

    // Jobs Collection Helper: Validates Job Schema
    function isValidJob(data) {
      return data.keys().hasAll(['id', 'title', 'location', 'isActive', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 256 &&
             data.location is string && data.location.size() <= 128 &&
             data.isActive is bool &&
             data.createdAt is string;
    }

    // Jobs Collection: Careers / Recruitment opportunities
    match /jobs/{jobId} {
      allow read: if true; // Public listing
      allow create: if isAdmin() && isValidId(jobId) && isValidJob(request.resource.data);
      allow update: if isAdmin() && isValidJob(request.resource.data);
      allow delete: if isAdmin();
    }

    // Clients Collection Helper: Validates Client Schema
    function isValidClient(data) {
      return data.keys().hasAll(['id', 'name', 'industry', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 256 &&
             data.industry is string && data.industry.size() <= 128 &&
             data.createdAt is string;
    }

    // Clients Collection: Enterprise partners
    match /clients/{clientId} {
      allow read: if isSignedIn() || isAdmin();
      allow create: if isAdmin() && isValidId(clientId) && isValidClient(request.resource.data);
      allow update: if isAdmin() && isValidClient(request.resource.data);
      allow delete: if isAdmin();
    }

    // Projects Collection Helper: Validates Project Schema
    function isValidProject(data) {
      return data.keys().hasAll(['id', 'name', 'clientId', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 256 &&
             data.clientId is string && data.clientId.size() <= 128 &&
             data.createdAt is string;
    }

    // Projects Collection: Outsourced project assignments
    match /projects/{projectId} {
      allow read: if isSignedIn() || isAdmin();
      allow create: if isAdmin() && isValidId(projectId) && isValidProject(request.resource.data);
      allow update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    // System Settings Collection
    match /system_settings/{settingId} {
      allow read, write: if isAdmin();
    }
  }
}
