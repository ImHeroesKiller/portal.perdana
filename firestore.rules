rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Ambil role dari collection 'users'
    function getUserRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isHR() {
      return isAuthenticated() && (getUserRole() == 'hr' || getUserRole() == 'admin');
    }

    function isProjectManager() {
      return isAuthenticated() && (getUserRole() == 'project_manager' || getUserRole() == 'admin');
    }

    function isViewer() {
      return isAuthenticated() && 
        (getUserRole() == 'viewer' || getUserRole() == 'hr' || 
         getUserRole() == 'project_manager' || getUserRole() == 'admin');
    }

    // ==================== USERS (Role Management) ====================
    match /users/{userId} {
      // User bisa baca data dirinya sendiri
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Hanya admin yang bisa create/update/delete user
      allow create, update, delete: if isAdmin();
    }

    // ==================== CANDIDATES (Data Pelamar - Sangat Sensitif) ====================
    match /candidates/{candidateId} {
      allow read: if isHR();
      allow create, update, delete: if isHR();
    }

    // ==================== APPLICATIONS (Lamaran Kerja) ====================
    match /applications/{applicationId} {
      allow read: if isHR();
      allow create, update, delete: if isHR();
    }

    // ==================== JOBS (Lowongan Kerja) ====================
    match /jobs/{jobId} {
      // HR & Admin bisa full access
      allow read, write: if isHR();
      
      // Viewer & Project Manager hanya boleh baca
      allow read: if isViewer();
    }

    // ==================== PROJECTS ====================
    match /projects/{projectId} {
      allow read: if isViewer();
      allow create, update, delete: if isProjectManager() || isAdmin();
    }

    // ==================== TASKS (Project Management) ====================
    match /tasks/{taskId} {
      allow read: if isViewer();
      allow create, update, delete: if isProjectManager() || isAdmin();
    }

    // ==================== EMPLOYEES ====================
    match /employees/{employeeId} {
      allow read: if isViewer();
      allow create, update, delete: if isAdmin() || isHR();
    }

    // ==================== CLIENTS ====================
    match /clients/{clientId} {
      allow read: if isViewer();
      allow create, update, delete: if isAdmin() || isProjectManager();
    }

    // ==================== SETTINGS ====================
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ==================== DEFAULT: DENY ALL ====================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}