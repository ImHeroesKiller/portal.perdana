# --- Server-only secrets (JANGAN prefix VITE_, jangan expose ke browser) ---

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI (Gemini — recruitment chat, AI interview analysis)
GEMINI_API_KEY=

# Grok AI (recruitment chat alternatif)
GROK_API_KEY=

# Admin API key untuk /api/db/seed/all (header: X-Api-Admin-Key)
API_ADMIN_SECRET=

# Firebase Admin SDK (serverless API routes)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIRESTORE_DATABASE_ID=

# --- Client-safe (VITE_ — akan dibundle ke browser) ---

# Firebase Client SDK (public config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=

# Error tracking (Sentry) — server API routes
SENTRY_DSN=

# Error tracking (Sentry) — client React app (boleh di-bundle)
VITE_SENTRY_DSN=

# Vercel Cron auth + uptime monitoring
CRON_SECRET=
# UPTIME_BASE_URL=https://portal.perada.net

# Firestore backup ke GCS (scripts + GitHub Actions)
# FIRESTORE_BACKUP_BUCKET=portal-perada-firestore-backups
# FIRESTORE_BACKUP_PREFIX=backups

# Opsional: allowed origins tambahan (comma-separated)
# ALLOWED_ORIGINS=